# Cloudflare R2 (S3-compatible) credentials
# Create an R2 API token in the Cloudflare dashboard (R2 > Manage API Tokens).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
# Optional: override the endpoint. If omitted it is derived from R2_ACCOUNT_ID:
# https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Optional: prefix inside the bucket where video folders live (default: videos/)
R2_VIDEO_PREFIX=videos/

# Site access (single shared password)
SITE_PASSWORD=change-me
# Secret used to sign the auth cookie. Use a long random string.
AUTH_SECRET=generate-a-long-random-string
